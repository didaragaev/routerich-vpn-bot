# VLESS TPROXY rules — own table, applied separately from fw4
table inet vless_tproxy {
    set local_ipv4 {
        type ipv4_addr
        flags interval
        elements = {
            0.0.0.0/8, 10.0.0.0/8, 100.64.0.0/10,
            127.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12,
            192.0.0.0/24, 192.0.2.0/24, 192.88.99.0/24,
            192.168.0.0/16, 198.18.0.0/15, 198.51.100.0/24,
            203.0.113.0/24, 224.0.0.0/4, 240.0.0.0/4
        }
    }

    chain prerouting {
        type filter hook prerouting priority mangle; policy accept;

        # пакеты исходящего Xray — не трогаем
        meta mark 255 accept

        # частные/локальные сети — не заворачивать
        ip daddr @local_ipv4 accept

        # loopback — не трогать
        iifname "lo" accept

        # трафик к самому роутеру (DNS, SSH) — не заворачивать
        fib daddr type local accept

        # транзитный TCP → TPROXY на Xray
        meta l4proto tcp tproxy ip to 127.0.0.1:12345 meta mark set 1 accept

        # транзитный UDP → TPROXY на Xray
        meta l4proto udp tproxy ip to 127.0.0.1:12345 meta mark set 1 accept
    }
}
